        { "key": "familyId", "type": "key", "attributes": ["familyId"] },
        { "key": "date", "type": "key", "attributes": ["date"] }
      ],
      "permissions": {
        "read": ["label:users"],
        "create": ["label:users"],
        "update": ["label:users"],
        "delete": ["label:users"]
      }
    },
    {
      "$id": "alcohol_logs",
      "name": "alcohol_logs",
      "attributes": [
