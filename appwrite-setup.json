      "indexes": [
        { "key": "familyId", "type": "key", "attributes": ["familyId"] },
        { "key": "assignedTo", "type": "key", "attributes": ["assignedTo"] }
      ],
      "permissions": {
        "read": ["label:users"],
        "create": ["label:users"],
        "update": ["label:users"],
        "delete": ["label:users"]
      }
    },
    {
